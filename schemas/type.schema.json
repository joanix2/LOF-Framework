{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "type.schema.json",
  "title": "Type Definition",
  "type": "object",
  "required": ["id"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the type"
    },
    "description": {
      "type": "string",
      "description": "Description of the type"
    },
    "dependsOn": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of type IDs this type depends on"
    },
    "parameters": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "description": { "type": "string" },
          "required": { "type": "boolean" },
          "default": {},
          "enum": {
            "type": "array",
            "items": {}
          }
        }
      }
    },
    "template": {
      "type": "string",
      "description": "Path to Jinja template file"
    },
    "targetType": {
      "type": "string",
      "description": "Reference to a target definition"
    },
    "interfaceSource": {
      "type": "string",
      "description": "Path to a static interface file to copy"
    },
    "outputPattern": {
      "type": "string",
      "description": "Pattern for output file path (Jinja template)"
    }
  },
  "additionalProperties": false
}
