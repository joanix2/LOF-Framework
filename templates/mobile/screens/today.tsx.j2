import { View, Text, ScrollView, TouchableOpacity } from 'react-native';
import { useMissions } from '../hooks/useMissions';
import { useEmployee } from '../hooks/useEmployee';
import { MissionCard } from '../components/MissionCard';
import { StatusBadge } from '../components/StatusBadge';

export default function TodayScreen() {
  const { employee } = useEmployee();
  const { getTodaysMissions, getCurrentMission } = useMissions();
  const today = new Date().toLocaleDateString('fr-FR', { weekday: 'long', day: 'numeric', month: 'long' });
  const currentMission = getCurrentMission();
  const missions = getTodaysMissions();

  return (
    <ScrollView style={{ flex: 1, backgroundColor: '#f5f5f5' }}>
      <View style={{ padding: 16, backgroundColor: '#1a73e8', borderRadius: 0 }}>
        <Text style={{ fontSize: 24, fontWeight: 'bold', color: '#fff' }}>
          Bonjour {{ instance.firstName }}
        </Text>
        <Text style={{ fontSize: 14, color: '#e0e0e0', marginTop: 4 }}>{{ today }}</Text>
        <Text style={{ fontSize: 14, color: '#e0e0e0' }}>{{ "{{ employee.team }}" }}</Text>
        <Text style={{ fontSize: 14, color: '#e0e0e0' }}>Véhicule: {{ "{{ employee.vehicle }}" }}</Text>
      </View>

      <View style={{ padding: 16 }}>
        <Text style={{ fontSize: 18, fontWeight: '600', marginBottom: 12 }}>Mission en cours</Text>
        {% if currentMission %}
        <MissionCard mission={currentMission} variant="large" />
        <View style={{ flexDirection: 'row', marginTop: 12, gap: 8 }}>
          <TouchableOpacity style={{ flex: 1, backgroundColor: '#1a73e8', padding: 12, borderRadius: 8 }}>
            <Text style={{ color: '#fff', textAlign: 'center', fontWeight: '600' }}>Voir la mission</Text>
          </TouchableOpacity>
          <TouchableOpacity style={{ flex: 1, backgroundColor: '#34a853', padding: 12, borderRadius: 8 }}>
            <Text style={{ color: '#fff', textAlign: 'center', fontWeight: '600' }}>Itinéraire</Text>
          </TouchableOpacity>
        </View>
        {% else %}
        <Text style={{ color: '#999', fontStyle: 'italic' }}>Aucune mission en cours</Text>
        {% endif %}
      </View>

      <View style={{ padding: 16 }}>
        <Text style={{ fontSize: 18, fontWeight: '600', marginBottom: 12 }}>Autres missions du jour</Text>
        {% for m in missions %}
        <MissionCard key={m.reference} mission={m} variant="small" />
        {% endfor %}
      </View>
    </ScrollView>
  );
}
