class Test{{ name | pascal_case }}Integration:
    @pytest.mark.asyncio
    async def test_full_crud_flow(self, async_client: AsyncClient):
        payload = {
{%- for field in fields %}
{%- set f_name = field.get('name', '') | snake_case %}
{%- set f_required = field.get('required', False) %}
{%- set f_generated = field.get('generated', False) %}
{%- if f_required and f_name not in ("id", "created_at", "updated_at") and not f_generated %}
{%- set f_type = field.get('type') %}
{%- if f_type == "email" %}
            "{{ f_name }}": "test@example.com",
{%- else %}
            "{{ f_name }}": "test-{{ f_name }}",
{%- endif %}
{%- endif %}
{%- endfor %}
        }
        create_resp = await async_client.post("/api/v1/{{ route }}", json=payload)
        assert create_resp.status_code == 201
        entity_id = create_resp.json()["id"]

        get_resp = await async_client.get(f"/api/v1/{{ route }}/{entity_id}")
        assert get_resp.status_code == 200
        assert get_resp.json()["id"] == entity_id

        list_resp = await async_client.get("/api/v1/{{ route }}")
        assert list_resp.status_code == 200
        assert list_resp.json()["total"] >= 1

        del_resp = await async_client.delete(f"/api/v1/{{ route }}/{entity_id}")
        assert del_resp.status_code == 204

        get_deleted = await async_client.get(f"/api/v1/{{ route }}/{entity_id}")
        assert get_deleted.status_code == 404
{%- endif %}
