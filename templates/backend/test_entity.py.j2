"""Tests for the {{ name | pascal_case }} API endpoints."""

import pytest
from httpx import AsyncClient


{% if "create" in operations %}
class TestCreate{{ name | pascal_case }}:
    @pytest.mark.asyncio
    async def test_create_{{ name | snake_case }}_success(self, async_client: AsyncClient):
        payload = {
{% for field in fields %}
{% if field.get('required') and field.get('name') != "id" and field.get('generated') != True %}
{% set f_type = field.get('type') %}
{% if f_type == "string" or f_type == "email" or f_type == "url" or f_type == "text" or f_type == "enum" %}
            "{{ field.get('name') }}": "test-{{ field.get('name') }}",
{% elif f_type in ("integer", "int") %}
            "{{ field.get('name') }}": 1,
{% elif f_type in ("float", "decimal") %}
            "{{ field.get('name') }}": 1.0,
{% elif f_type in ("boolean", "bool") %}
            "{{ field.get('name') }}": true,
{% elif f_type == "uuid" %}
            "{{ field.get('name') }}": "00000000-0000-0000-0000-000000000000",
{% elif f_type in ("datetime", "date") %}
            "{{ field.get('name') }}": "2024-01-01T00:00:00",
{% else %}
            "{{ field.get('name') }}": "test-value",
{% endif %}
{% endif %}
{% endfor %}
        }
        response = await async_client.post("/api/v1/{{ route }}", json=payload)
        assert response.status_code == 201
        data = response.json()
        assert data["{{ fields[1].get('name') if fields|length > 1 else 'name' }}"] == payload["{{ fields[1].get('name') if fields|length > 1 else 'name' }}"]
        assert "id" in data

    @pytest.mark.asyncio
    async def test_create_{{ name | snake_case }}_validation_error(self, async_client: AsyncClient):
        response = await async_client.post("/api/v1/{{ route }}", json={})
        assert response.status_code == 422

{% endif %}

{% if "list" in operations %}
class TestList{{ name | pascal_case }}:
    @pytest.mark.asyncio
    async def test_list_{{ name | snake_case }}_empty(self, async_client: AsyncClient):
        response = await async_client.get("/api/v1/{{ route }}")
        assert response.status_code == 200
        data = response.json()
        assert data["total"] == 0
        assert data["items"] == []

    @pytest.mark.asyncio
    async def test_list_{{ name | snake_case }}_pagination(self, async_client: AsyncClient):
        response = await async_client.get("/api/v1/{{ route }}?page=1&page_size=10")
        assert response.status_code == 200
        data = response.json()
        assert "items" in data
        assert "total" in data
        assert "page" in data
        assert data["page"] == 1

    @pytest.mark.asyncio
    async def test_list_{{ name | snake_case }}_sorting(self, async_client: AsyncClient):
        response = await async_client.get("/api/v1/{{ route }}?sort_by=created_at&sort_desc=true")
        assert response.status_code == 200

{% endif %}

