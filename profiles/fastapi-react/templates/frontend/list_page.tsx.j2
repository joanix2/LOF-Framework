import { useMemo, useState } from 'react'
import { Link } from 'react-router-dom'
import type { ColumnDef } from '@tanstack/react-table'
import { use{{ id | pascal_case }}List, useDelete{{ id | pascal_case }} } from '../hooks/use{{ id | pascal_case }}'
import type { {{ id | pascal_case }} } from '../types/{{ id }}'
import { DataTable } from '../components/data-table'
import { Button } from '../components/ui/button'
import {
  Dialog, DialogContent, DialogDescription, DialogFooter,
  DialogHeader, DialogTitle,
} from '../components/ui/dialog'

export default function {{ id | pascal_case }}ListPage() {
  const [page, setPage] = useState(1)
  const [search, setSearch] = useState('')
  const [sortField, setSortField] = useState<string | undefined>()
  const [sortDir, setSortDir] = useState<'asc' | 'desc' | undefined>()
  const { data, isLoading, error } = use{{ id | pascal_case }}List(page, 20, search || undefined)
  const deleteMutation = useDelete{{ id | pascal_case }}()
  const [confirmDelete, setConfirmDelete] = useState<string | null>(null)
  const [deleteError, setDeleteError] = useState<string | null>(null)

  const handleDelete = async (id: string) => {
    try {
      await deleteMutation.mutateAsync(id)
      setConfirmDelete(null)
    } catch (e) {
      setDeleteError('Failed to delete')
    }
  }

  const columns = useMemo<ColumnDef<{{ id | pascal_case }}>[]>(() => [
{% for field in fields %}
{% if field.get('list_visible', True) %}
{% set f_type = field.get('type', 'string') %}
{% set f_name = field.get('name') %}
    {
      accessorKey: '{{ f_name }}',
      header: '{{ f_name | capitalize }}',
{% if f_type in ("boolean", "bool") %}
      cell: ({ row }) => row.original.{{ f_name }} ? '\u2713' : '\u2717',
{% elif f_type in ("datetime", "date") %}
      cell: ({ row }) => new Date(row.original.{{ f_name }}).toLocaleDateString(),
{% endif %}
    },
{% endif %}
{% endfor %}
    {
      id: 'actions',
      header: 'Actions',
      cell: ({ row }) => (
        <div className="flex gap-1 justify-end">
          <Link to={`/{{ route }}/${row.original.id}`}>
            <Button variant="outline" size="sm">View</Button>
          </Link>
          <Link to={`/{{ route }}/${row.original.id}/edit`}>
            <Button variant="secondary" size="sm">Edit</Button>
          </Link>
          <Button variant="destructive" size="sm" onClick={() => setConfirmDelete(row.original.id)}>
            Delete
          </Button>
        </div>
      ),
    },
  ], [])

  if (isLoading) return <div className="flex items-center justify-center h-64 text-muted-foreground">Loading...</div>
  if (error) return <div className="text-destructive p-4">Error loading {{ pluralName | lower }}</div>

  return (
    <div className="p-6 space-y-6">
      <div className="flex items-center justify-between">
        <h1 className="text-3xl font-bold tracking-tight">{{ pluralName }}</h1>
        <Link to="/{{ route }}/new">
          <Button>New {{ id | pascal_case }}</Button>
        </Link>
      </div>

      <DataTable<{{ id | pascal_case }}>
        columns={columns}
        data={data?.items || []}
        total={data?.total}
        searchColumn={search ? undefined : undefined}
        searchPlaceholder="Search {{ pluralName | lower }}..."
        toolbar={undefined}
      />

      <Dialog open={!!confirmDelete} onOpenChange={(o) => { if (!o) setConfirmDelete(null); setDeleteError(null) }}>
        <DialogContent>
          <DialogHeader>
            <DialogTitle>Confirm Deletion</DialogTitle>
            <DialogDescription>
              Are you sure you want to delete this {{ name | lower }}? This action cannot be undone.
            </DialogDescription>
          </DialogHeader>
          {deleteError && <p className="text-sm text-destructive">{deleteError}</p>}
          <DialogFooter>
            <Button variant="outline" onClick={() => setConfirmDelete(null)}>Cancel</Button>
            <Button variant="destructive" onClick={() => handleDelete(confirmDelete!)} disabled={deleteMutation.isPending}>
              {deleteMutation.isPending ? 'Deleting...' : 'Delete'}
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>
    </div>
  )
}
