import { useState } from 'react'
import { Link } from 'react-router-dom'
import { use{{ id | pascal_case }}List, useDelete{{ id | pascal_case }} } from '../hooks/use{{ id | pascal_case }}'
import type { {{ id | pascal_case }} } from '../types/{{ id }}'
import { Button } from '../components/ui/button'
import { Input } from '../components/ui/input'
import { Card, CardContent, CardHeader, CardTitle } from '../components/ui/card'
import {
  Table, TableBody, TableCell, TableHead, TableHeader, TableRow,
} from '../components/ui/table'
import {
  Dialog, DialogContent, DialogDescription, DialogFooter,
  DialogHeader, DialogTitle,
} from '../components/ui/dialog'

export default function {{ id | pascal_case }}ListPage() {
  const [page, setPage] = useState(1)
  const [search, setSearch] = useState('')
  const { data, isLoading, error } = use{{ id | pascal_case }}List(page, 20, search || undefined)
  const deleteMutation = useDelete{{ id | pascal_case }}()
  const [confirmDelete, setConfirmDelete] = useState<string | null>(null)
  const [deleteError, setDeleteError] = useState<string | null>(null)

  const handleDelete = async (id: string) => {
    try {
      await deleteMutation.mutateAsync(id)
      setConfirmDelete(null)
    } catch (e) {
      setDeleteError('Failed to delete')
    }
  }

  if (isLoading) return <div className="flex items-center justify-center h-64 text-muted-foreground">Loading...</div>
  if (error) return <div className="text-destructive p-4">Error loading {{ pluralName | lower }}</div>

  return (
    <div className="p-6 space-y-6">
      <div className="flex items-center justify-between">
        <h1 className="text-3xl font-bold tracking-tight">{{ pluralName }}</h1>
        <Link to="/{{ route }}/new">
          <Button>New {{ id | pascal_case }}</Button>
        </Link>
      </div>

      <Card>
        <CardHeader className="pb-3">
          <CardTitle>Search</CardTitle>
        </CardHeader>
        <CardContent>
          <Input
            placeholder="Search {{ pluralName | lower }}..."
            value={search}
            onChange={(e) => { setSearch(e.target.value); setPage(1) }}
            className="max-w-sm"
          />
        </CardContent>
      </Card>

      <Card>
        <CardContent className="p-0">
          <Table>
            <TableHeader>
              <TableRow>
{% for field in fields %}
{% if field.get('list_visible', True) %}
                <TableHead>{{ field.get('name') }}</TableHead>
{% endif %}
{% endfor %}
                <TableHead className="text-right">Actions</TableHead>
              </TableRow>
            </TableHeader>
            <TableBody>
              {data?.items.map((item: {{ id | pascal_case }}) => (
                <TableRow key={item.id}>
{% for field in fields %}
{% if field.get('list_visible', True) %}
{% set f_type = field.get('type', 'string') %}
{% set f_name = field.get('name') %}
{% if f_type in ("boolean", "bool") %}
                  <TableCell>{item.{{ f_name }} ? '\u2713' : '\u2717'}</TableCell>
{% elif f_type in ("datetime", "date") %}
                  <TableCell>{new Date(item.{{ f_name }}).toLocaleDateString()}</TableCell>
{% else %}
                  <TableCell>{item.{{ f_name }}}</TableCell>
{% endif %}
{% endif %}
{% endfor %}
                  <TableCell className="text-right">
                    <Link to={`/{{ route }}/${item.id}`}>
                      <Button variant="outline" size="sm" className="mr-2">View</Button>
                    </Link>
                    <Link to={`/{{ route }}/${item.id}/edit`}>
                      <Button variant="secondary" size="sm" className="mr-2">Edit</Button>
                    </Link>
                    <Button variant="destructive" size="sm" onClick={() => setConfirmDelete(item.id)}>
                      Delete
                    </Button>
                  </TableCell>
                </TableRow>
              ))}
            </TableBody>
          </Table>
        </CardContent>
      </Card>

      {data && (
        <div className="flex items-center justify-between">
          <p className="text-sm text-muted-foreground">
            Page {data.page} of {data.total_pages} ({data.total} total)
          </p>
          <div className="flex gap-2">
            <Button
              variant="outline"
              size="sm"
              onClick={() => setPage((p: number) => Math.max(1, p - 1))}
              disabled={page <= 1}
            >
              Previous
            </Button>
            <Button
              variant="outline"
              size="sm"
              onClick={() => setPage((p: number) => p + 1)}
              disabled={page >= (data?.total_pages || 1)}
            >
              Next
            </Button>
          </div>
        </div>
      )}

      <Dialog open={!!confirmDelete} onOpenChange={(o) => { if (!o) setConfirmDelete(null); setDeleteError(null) }}>
        <DialogContent>
          <DialogHeader>
            <DialogTitle>Confirm Deletion</DialogTitle>
            <DialogDescription>
              Are you sure you want to delete this {{ name | lower }}? This action cannot be undone.
            </DialogDescription>
          </DialogHeader>
          {deleteError && <p className="text-sm text-destructive">{deleteError}</p>}
          <DialogFooter>
            <Button variant="outline" onClick={() => setConfirmDelete(null)}>Cancel</Button>
            <Button variant="destructive" onClick={() => handleDelete(confirmDelete!)} disabled={deleteMutation.isPending}>
              {deleteMutation.isPending ? 'Deleting...' : 'Delete'}
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>
    </div>
  )
}
