import { useForm } from 'react-hook-form'
import type { {{ id | pascal_case }}Create, {{ id | pascal_case }}Update } from '../types/{{ id }}'
import { Button } from '../components/ui/button'
import { Input } from '../components/ui/input'
import { Textarea } from '../components/ui/textarea'
import { Label } from '../components/ui/label'
import { Card, CardContent } from '../components/ui/card'
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '../components/ui/select'

interface {{ id | pascal_case }}FormProps {
  initialData?: {{ id | pascal_case }}Create
  onSubmit: (data: {{ id | pascal_case }}Create | {{ id | pascal_case }}Update) => void
  isSubmitting?: boolean
}

export default function {{ id | pascal_case }}Form({ initialData, onSubmit, isSubmitting }: {{ id | pascal_case }}FormProps) {
  const { register, handleSubmit, formState: { errors } } = useForm({
    defaultValues: initialData || {},
  })

  return (
    <form onSubmit={handleSubmit(onSubmit)} className="space-y-6">
      <Card>
        <CardContent className="pt-6 space-y-4">
{% for field in fields %}
{% set f_name = field.get('name') %}
{% set f_visible = field.get('visibleInForm', True) %}
{% if f_visible and f_name != "id" %}
{% set f_type = field.get('type', 'string') %}
{% set f_required = field.get('required', False) %}
{% set f_enum = field.get('enum_ref') %}
          <div className="space-y-2">
            <Label htmlFor="{{ f_name }}">{{ f_name | capitalize }}</Label>
{% if f_type in ("boolean", "bool") %}
            <div className="flex items-center gap-2 pt-1">
              <input type="checkbox" id="{{ f_name }}" {...register('{{ f_name }}')} className="h-4 w-4" />
            </div>
{% elif f_type == "text" %}
            <Textarea
              id="{{ f_name }}"
              {...register('{{ f_name }}', { required: {{ "true" if f_required else "false" }} })}
              rows={4}
            />
            {errors.{{ f_name }} && <p className="text-sm text-destructive">Required</p>}
{% elif f_enum %}
            <select
              id="{{ f_name }}"
              {...register('{{ f_name }}', { required: {{ "true" if f_required else "false" }} })}
              className="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm"
            >
              <option value="">Select...</option>
            </select>
            {errors.{{ f_name }} && <p className="text-sm text-destructive">Required</p>}
{% else %}
{% set input_type = "email" if f_type == "email" else "number" if f_type in ("integer", "int", "float", "decimal", "money") else "datetime-local" if f_type in ("datetime", "date") else "text" %}
            <Input
              id="{{ f_name }}"
              type="{{ input_type }}"
              {...register('{{ f_name }}', { required: {{ "true" if f_required else "false" }} })}
            />
            {errors.{{ f_name }} && <p className="text-sm text-destructive">Required</p>}
{% endif %}
          </div>
{% endif %}
{% endfor %}
        </CardContent>
      </Card>

      <div className="flex gap-2 justify-end">
        <Button type="submit" disabled={isSubmitting}>
          {isSubmitting ? 'Saving...' : 'Save'}
        </Button>
      </div>
    </form>
  )
}
