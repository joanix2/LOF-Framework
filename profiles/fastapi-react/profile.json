{
  "id": "fastapi-react",
  "version": "0.2.0",
  "description": "FastAPI backend + React frontend with full CRUD",
  "inverse_relation_kinds": {
    "many-to-one": "one-to-many",
    "one-to-one": "one-to-one",
    "one-to-many": "many-to-one",
    "many-to-many": "many-to-many"
  },
  "naming": {
    "route": "kebab",
    "table": "snake",
    "foreign_key": "{target}_id",
    "target_display_field": "id",
    "plural": "append_s"
  },
  "defaults": {
    "operations": [
      "create",
      "read",
      "update",
      "delete",
      "list",
      "search"
    ],
    "audit_fields": [
      "created_at",
      "updated_at"
    ],
    "auto_id_field": {
      "name": "id",
      "type": "uuid",
      "primary": true,
      "generated": true
    },
    "capabilities": {
      "create": true,
      "read": true,
      "update": true,
      "delete": true,
      "list": true,
      "search": true,
      "pagination": true,
      "export": false
    }
  },
  "projections": [
    {
      "type": "model",
      "condition": "always",
      "template": ".lof/templates/backend/model.py.j2",
      "outputPattern": "generated-project/apps/api/src/app/modules/{{ id }}/model.py",
      "targetType": "python-module"
    },
    {
      "type": "schema",
      "condition": "always",
      "template": ".lof/templates/backend/schemas.py.j2",
      "outputPattern": "generated-project/apps/api/src/app/modules/{{ id }}/schemas.py",
      "targetType": "python-module"
    },
    {
      "type": "route",
      "condition": "has_operations",
      "template": ".lof/templates/backend/router.py.j2",
      "outputPattern": "generated-project/apps/api/src/app/modules/{{ id }}/router.py",
      "targetType": "python-module"
    },
    {
      "type": "api-test",
      "condition": "has_operations",
      "template": ".lof/templates/backend/test_entity.py.j2",
      "outputPattern": "generated-project/apps/api/tests/modules/test_{{ id }}.py",
      "targetType": "python-module"
    },
    {
      "type": "data-grid",
      "condition": "capability.list",
      "template": ".lof/templates/frontend/list_page.tsx.j2",
      "outputPattern": "generated-project/apps/web/src/pages/{{ id | pascal_case }}ListPage.tsx",
      "targetType": "react-component"
    },
    {
      "type": "form",
      "condition": "has_operations",
      "template": ".lof/templates/frontend/form.tsx.j2",
      "outputPattern": "generated-project/apps/web/src/components/{{ id | pascal_case }}Form.tsx",
      "targetType": "react-component"
    },
    {
      "type": "hook",
      "condition": "has_operations",
      "template": ".lof/templates/frontend/hooks.ts.j2",
      "outputPattern": "generated-project/apps/web/src/hooks/use{{ id | pascal_case }}.ts",
      "targetType": "typescript-module"
    },
    {
      "type": "type",
      "condition": "always",
      "template": ".lof/templates/frontend/types.ts.j2",
      "outputPattern": "generated-project/apps/web/src/types/{{ id }}.ts",
      "targetType": "typescript-module"
    },
    {
      "type": "e2e-test",
      "condition": "capability.list",
      "template": ".lof/templates/frontend/test_e2e.ts.j2",
      "outputPattern": "generated-project/apps/web/e2e/{{ id }}.spec.ts",
      "targetType": "typescript-module"
    },
    {
      "type": "repository",
      "condition": "has_operations",
      "template": ".lof/templates/backend/repository.py.j2",
      "outputPattern": "generated-project/apps/api/src/app/modules/{{ id }}/repository.py",
      "targetType": "python-module"
    },
    {
      "type": "service",
      "condition": "has_operations",
      "template": ".lof/templates/backend/service.py.j2",
      "outputPattern": "generated-project/apps/api/src/app/modules/{{ id }}/service.py",
      "targetType": "python-module"
    }
  ],
  "closed_world_predicates": [
    "has_operation",
    "field_type",
    "requires_projection",
    "requires_endpoint",
    "form_widget"
  ],
  "verb_normalization": {
    "voir": "read",
    "consulter": "read",
    "lire": "read",
    "afficher": "read",
    "cr\u00e9er": "create",
    "creer": "create",
    "ajouter": "create",
    "nouveau": "create",
    "modifier": "update",
    "\u00e9diter": "update",
    "editer": "update",
    "changer": "update",
    "supprimer": "delete",
    "effacer": "delete",
    "retirer": "delete",
    "enlever": "delete",
    "lister": "list",
    "afficher_tous": "list",
    "commenter": "comment",
    "r\u00e9pondre": "comment",
    "repondre": "comment",
    "valider": "validate",
    "approuver": "validate",
    "confirmer": "validate",
    "chercher": "search",
    "rechercher": "search",
    "trouver": "search"
  },
  "widget_mapping": {
    "enum": "select",
    "boolean": "checkbox",
    "bool": "checkbox",
    "text": "textarea",
    "datetime": "datepicker",
    "date": "datepicker",
    "email": "email_input"
  },
