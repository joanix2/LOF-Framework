{
  "id": "entity-list-page",
  "template": ".lof/templates/frontend/list_page.tsx.j2",
  "targetType": "react-component",
  "outputPattern": "generated-project/apps/web/src/pages/{{ name | pascal_case }}ListPage.tsx",
  "parameters": {
    "name": {
      "type": "string",
      "required": true
    },
    "fields": {
      "type": "array",
      "required": true
    },
    "pluralName": {
      "type": "string",
      "required": true
    },
    "route": {
      "type": "string",
      "required": true
    }
  }
}