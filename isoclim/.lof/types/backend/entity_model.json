{
  "id": "entity-model",
  "template": ".lof/templates/backend/model.py.j2",
  "targetType": "python-module",
  "outputPattern": "generated-project/apps/api/src/app/modules/{{ name | snake_case }}/model.py",
  "parameters": {
    "name": {
      "type": "string",
      "required": true
    },
    "fields": {
      "type": "array",
      "required": true
    },
    "tableName": {
      "type": "string",
      "required": true
    }
  }
}