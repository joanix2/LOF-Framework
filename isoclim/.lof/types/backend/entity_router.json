{
  "id": "entity-router",
  "template": ".lof/templates/backend/router.py.j2",
  "targetType": "python-module",
  "outputPattern": "generated-project/apps/api/src/app/modules/{{ name | snake_case }}/router.py",
  "parameters": {
    "name": {
      "type": "string",
      "required": true
    },
    "route": {
      "type": "string",
      "required": true
    },
    "pluralName": {
      "type": "string",
      "required": true
    },
    "operations": {
      "type": "array"
    }
  }
}