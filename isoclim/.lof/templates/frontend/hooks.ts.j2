export function useCreate{{ name | pascal_case }}() {
  const queryClient = useQueryClient();
  return useMutation({
    mutationFn: async (data: {{ name | pascal_case }}Create) => {
      const res = await fetch(`${API_BASE}/{{ route }}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
