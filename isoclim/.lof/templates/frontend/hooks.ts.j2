import type { {{ name | pascal_case }}, {{ name | pascal_case }}Create, {{ name | pascal_case }}Update, {{ name | pascal_case }}Page } from '../types/{{ name | snake_case }}';

const API_BASE = import.meta.env.VITE_API_URL || 'http://localhost:8000/api/v1';

export function use{{ name | pascal_case }}List(page = 1, pageSize = 20, search?: string) {
  return useQuery<{{ name | pascal_case }}Page>({
    queryKey: ['{{ name | snake_case }}', 'list', page, pageSize, search],
    queryFn: async () => {
