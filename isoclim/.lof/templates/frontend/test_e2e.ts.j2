import { test, expect } from '@playwright/test';

test.describe('{{ pluralName }}', () => {
  test.beforeEach(async ({ page }) => {
    await page.goto('/{{ route }}');
  });

  test('displays the list page', async ({ page }) => {
    await expect(page.getByText('{{ pluralName }}')).toBeVisible();
  });

  test('can navigate to create form', async ({ page }) => {
    await page.getByText('New {{ name | pascal_case }}').click();
    await expect(page.url()).toContain('/{{ route }}/new');
  });

  test('shows loading state', async ({ page }) => {
    await expect(page.getByText('Loading...')).toBeVisible();
  });
});
