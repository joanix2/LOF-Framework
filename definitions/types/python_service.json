{
  "$schema": "../../schemas/type.schema.json",
  "id": "python-service",
  "description": "Python service class depending on an entity",
  "dependsOn": [
    "named-element",
    "python-entity"
  ],
  "parameters": {
    "name": {
      "type": "string",
      "required": true
    },
    "entity_name": {
      "type": "string",
      "required": true,
      "description": "Name of the entity this service manages"
    }
  },
  "template": "templates/python/service.py.j2",
  "targetType": "python-module",
  "outputPattern": "generated/python/{{ name | snake_case }}_service.py"
}
