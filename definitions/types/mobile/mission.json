{
  "id": "mission",
  "description": "Field mission for a technician",
  "depends_on": ["employee", "client"],
  "parameters": {
    "reference": {"type": "string", "required": true},
    "title": {"type": "string", "required": true},
    "status": {"type": "string", "enum": ["planned", "in_progress", "paused", "blocked", "completed"]},
    "priority": {"type": "string", "enum": ["normal", "urgent"]},
    "description": {"type": "string"},
    "startTime": {"type": "string"},
    "endTime": {"type": "string"},
    "estimatedDuration": {"type": "number"},
    "clientId": {"type": "string"},
    "worksiteId": {"type": "string"},
    "teamMembers": {"type": "array"},
    "safetyChecklist": {"type": "array"},
    "equipmentChecklist": {"type": "array"},
    "materialChecklist": {"type": "array"}
  },
  "targetType": "expo-service"
}
