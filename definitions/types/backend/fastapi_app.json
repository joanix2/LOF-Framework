{
  "$schema": "../../../schemas/type.schema.json",
  "id": "fastapi-app",
  "description": "FastAPI application bootstrap",
  "parameters": {
    "title": { "type": "string", "default": "FastAPI Application" },
    "version": { "type": "string", "default": "0.1.0" },
    "apiPrefix": { "type": "string", "default": "/api/v1" },
    "modules": { "type": "array", "required": true },
    "databaseUrl": { "type": "string", "default": "sqlite+aiosqlite:///./app.db" }
  },
  "template": "templates/backend/main.py.j2",
  "targetType": "python-module",
  "outputPattern": "generated-project/apps/api/src/app/main.py"
}
