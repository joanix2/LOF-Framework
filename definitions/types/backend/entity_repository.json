{
  "$schema": "../../../schemas/type.schema.json",
  "id": "entity-repository",
  "description": "Repository for an entity",
  "dependsOn": ["entity-model", "entity-schemas"],
  "parameters": {
    "name": { "type": "string", "required": true },
    "tableName": { "type": "string", "required": true },
    "fields": { "type": "array", "required": true },
    "searchableFields": { "type": "array", "default": [] }
  },
  "template": "templates/backend/repository.py.j2",
  "targetType": "python-module",
  "outputPattern": "generated-project/apps/api/src/app/modules/{{ name | snake_case }}/repository.py"
}
