{
  "$schema": "../../../schemas/type.schema.json",
  "id": "backend-tests",
  "description": "Pytest tests for a backend entity module",
  "dependsOn": ["entity-router", "entity-service", "entity-repository"],
  "parameters": {
    "name": { "type": "string", "required": true },
    "pluralName": { "type": "string", "required": true },
    "fields": { "type": "array", "required": true },
    "route": { "type": "string", "required": true },
    "operations": { "type": "array", "default": ["create","read","update","delete","list","search"] }
  },
  "template": "templates/backend/test_entity.py.j2",
  "targetType": "python-module",
  "outputPattern": "generated-project/apps/api/tests/modules/test_{{ name | snake_case }}.py"
}
