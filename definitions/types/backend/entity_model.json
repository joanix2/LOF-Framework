{
  "$schema": "../../../schemas/type.schema.json",
  "id": "entity-model",
  "description": "SQLAlchemy model for an entity",
  "dependsOn": [],
  "parameters": {
    "name": {
      "type": "string",
      "required": true
    },
    "tableName": {
      "type": "string",
      "required": true
    },
    "fields": {
      "type": "array",
      "required": true
    },
    "idType": {
      "type": "string",
      "default": "uuid"
    }
  },
  "template": "templates/backend/model.py.j2",
  "targetType": "python-module",
  "outputPattern": "generated-project/apps/api/src/app/modules/{{ name | snake_case }}/model.py"
}