{
  "$schema": "../../../schemas/type.schema.json",
  "id": "entity-types",
  "description": "TypeScript types for an entity",
  "parameters": {
    "name": { "type": "string", "required": true },
    "fields": { "type": "array", "required": true }
  },
  "template": "templates/frontend/types.ts.j2",
  "targetType": "typescript-module",
  "outputPattern": "generated-project/apps/web/src/types/{{ name | snake_case }}.ts"
}
