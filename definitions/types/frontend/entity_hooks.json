{
  "$schema": "../../../schemas/type.schema.json",
  "id": "entity-hooks",
  "description": "TanStack Query hooks for an entity",
  "dependsOn": ["entity-types"],
  "parameters": {
    "name": { "type": "string", "required": true },
    "route": { "type": "string", "required": true },
    "pluralName": { "type": "string", "required": true }
  },
  "template": "templates/frontend/hooks.ts.j2",
  "targetType": "typescript-module",
  "outputPattern": "generated-project/apps/web/src/hooks/use{{ name | pascal_case }}.ts"
}
