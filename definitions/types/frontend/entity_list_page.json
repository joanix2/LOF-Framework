{
  "$schema": "../../../schemas/type.schema.json",
  "id": "entity-list-page",
  "description": "React list page for an entity",
  "dependsOn": ["entity-hooks", "entity-types"],
  "parameters": {
    "name": { "type": "string", "required": true },
    "pluralName": { "type": "string", "required": true },
    "route": { "type": "string", "required": true },
    "fields": { "type": "array", "required": true }
  },
  "template": "templates/frontend/list_page.tsx.j2",
  "targetType": "react-component",
  "outputPattern": "generated-project/apps/web/src/pages/{{ name | pascal_case }}ListPage.tsx"
}
