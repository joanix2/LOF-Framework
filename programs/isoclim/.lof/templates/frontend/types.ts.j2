export interface {{ id | pascal_case }} {
{% for field in fields %}
{% set f_type = field.get('type', 'string') %}
{% set ts_type = "string" if f_type in ("uuid", "UUID", "string", "email", "url", "text", "enum", "datetime", "date") else "number" if f_type in ("integer", "int", "float", "decimal") else "boolean" if f_type in ("boolean", "bool") else "string" %}
  {{ field.get('name') }}: {{ ts_type }};
{% endfor %}
}

export interface {{ id | pascal_case }}Create {
{% for field in fields %}
{% set f_name = field.get('name') %}
{% if f_name != "id" %}
{% set f_type = field.get('type', 'string') %}
{% set ts_type = "string" if f_type in ("uuid", "UUID", "string", "email", "url", "text", "enum", "datetime", "date") else "number" if f_type in ("integer", "int", "float", "decimal") else "boolean" if f_type in ("boolean", "bool") else "string" %}
  {{ f_name }}{% if not field.get('required', False) %}?{% endif %}: {{ ts_type }};
{% endif %}
{% endfor %}
}

export interface {{ id | pascal_case }}Update {
{% for field in fields %}
{% set f_name = field.get('name') %}
{% if f_name != "id" %}
{% set f_type = field.get('type', 'string') %}
{% set ts_type = "string" if f_type in ("uuid", "UUID", "string", "email", "url", "text", "enum", "datetime", "date") else "number" if f_type in ("integer", "int", "float", "decimal") else "boolean" if f_type in ("boolean", "bool") else "string" %}
  {{ f_name }}?: {{ ts_type }};
{% endif %}
{% endfor %}
}

export interface {{ id | pascal_case }}Page {
  items: {{ id | pascal_case }}[];
  total: number;
  page: number;
  page_size: number;
  total_pages: number;
}
