import { Routes, Route, Navigate } from 'react-router-dom'
import { Suspense, lazy } from 'react'

const pages = [
{% for module in modules %}
  { path: '{{ module | kebab_case }}', label: '{{ module | pascal_case | pluralize }}', component: lazy(() => import('./pages/{{ module | pascal_case }}ListPage')) },
{% endfor %}
]

export default function App() {
  return (
    <div className="min-h-screen bg-gray-50">
      <nav className="bg-white shadow-md border-b px-6 py-3 flex gap-6 items-center">
        <h1 className="text-xl font-bold text-blue-700">{{ title }}</h1>
        {pages.map((p) => (
          <a key={p.path} href={`/${p.path}`} className="text-gray-600 hover:text-blue-600 text-sm font-medium">
            {p.label}
          </a>
        ))}
      </nav>
      <main className="p-6 max-w-7xl mx-auto">
        <Suspense fallback={<div className="text-center py-20 text-gray-400">Chargement...</div>}>
          <Routes>
            <Route path="/" element={<Navigate to="/{{ modules[0] | kebab_case }}" replace />} />
            {pages.map((p) => (
              <Route key={p.path} path={`/${p.path}`} element={<p.component />} />
            ))}
          </Routes>
        </Suspense>
      </main>
    </div>
  )
}
