{%- elif f_type == "text" %}
    {{ f_name }} = Column(Text, nullable={% if f_nullable %}True{% else %}False{% endif %})
{%- elif f_type in ("boolean", "bool") %}
    {{ f_name }} = Column(Boolean, default={% if field.get('default', False) %}True{% else %}False{% endif %}, nullable=False)
{%- elif f_type in ("datetime", "date") %}
    {{ f_name }} = Column(DateTime, default=datetime.utcnow{% if not f_nullable %}, nullable=False{% endif %})
{%- elif f_type in ("integer", "int") %}
    {{ f_name }} = Column(Integer, default={{ field.get('default', 0) }}, nullable=False)
{%- elif f_type in ("float", "decimal") %}
